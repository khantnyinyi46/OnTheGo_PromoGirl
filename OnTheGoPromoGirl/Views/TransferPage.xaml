<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OnTheGoPromoGirl.Views.TransferPage"
             xmlns:telerik="http://schemas.telerik.com/2022/xaml/maui"
             xmlns:local="clr-namespace:OnTheGoPromoGirl">
    
    <Shell.BackButtonBehavior>

        <BackButtonBehavior IsEnabled="False" IsVisible="False"/>

    </Shell.BackButtonBehavior>

    <Shell.TitleView>

        <StackLayout Orientation="Horizontal" Spacing="3" HorizontalOptions="FillAndExpand" Padding="10">
            <Label Text="Transfer"
                   VerticalOptions="Center"
                   FontSize="Title"
                   TextColor="White"
                   HorizontalOptions="StartAndExpand"/>

            <telerik:RadButton x:Name="forwardBtn"
                               Text="To Promotional Items"
                               ImageSource="ic_forward.png"
                               ContentLayout="right"
                               Clicked="forwardBtn_Clicked"
                               BackgroundColor="Transparent"
                               BorderColor="White"
                               BorderThickness="1"
                               HeightRequest="40"
                               HorizontalOptions="End">
            </telerik:RadButton>

        </StackLayout>

    </Shell.TitleView>


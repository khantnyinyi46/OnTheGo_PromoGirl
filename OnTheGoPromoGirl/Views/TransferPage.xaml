    <ContentPage.Resources>
        <DataTemplate x:Key="DefaultTemplate">
                <StackLayout Padding="10" Orientation="Horizontal">
                    <Label Text="{Binding SalesPersonID}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                    <Label Text="{Binding SalesPersonName}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                    <Label Text="{Binding TransferQty}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                </StackLayout>
        </DataTemplate>
        <DataTemplate x:Key="SpecialTemplate">

                <StackLayout Padding="10" Orientation="Horizontal" BackgroundColor="LightGreen">
                    <Label Text="{Binding SalesPersonID}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                    <Label Text="{Binding SalesPersonName}" FontSize="Caption" HorizontalOptions="FillAndExpand"/>
                    <Label Text="{Binding TransferQty}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                </StackLayout>

        </DataTemplate>
        <local:MyItemTemplateSelector x:Key="MyItemTemplateSelector"
                                      DefaultTemplate="{StaticResource DefaultTemplate}"
                                      SpecialTemplate="{StaticResource SpecialTemplate}" />
    </ContentPage.Resources>


    <Grid x:Name="grid" RowSpacing="5" Padding="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>

        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="10,10,10,0" VerticalOptions="Start">
            <StackLayout Orientation="Horizontal">

                <Label Text="Transfer ID"
                       HorizontalOptions="FillAndExpand"
                       VerticalOptions="Center"/>

                <Label x:Name="transferID"
                       HorizontalOptions="FillAndExpand"
                       FontSize="Caption"/>

                <Label x:Name="emptyLbl_1" HorizontalOptions="End"/>

            </StackLayout>

            <StackLayout Orientation="Horizontal">

                <Label Text="Item Name"
                       HorizontalOptions="FillAndExpand"
                       VerticalOptions="Center"/>

                <Label x:Name="itemName"
                       FontSize="Caption"
                       HorizontalOptions="FillAndExpand"/>

                <telerik:RadButton x:Name="itemSearchBtn"
                                   Clicked="itemSearch_Clicked"
                                   BackgroundImage="ic_search.png"
                                   BackgroundColor="Transparent"
                                   IsVisible="True"
                                   HeightRequest="40"
                                   WidthRequest="40"
                                   HorizontalOptions="End"/>

            </StackLayout>

            <StackLayout Orientation="Horizontal">

                <Label Text="Unit of Measure"
                       HorizontalOptions="FillAndExpand"
                       VerticalOptions="FillAndExpand"/>

                <Label Text="PCS"
                       HorizontalOptions="FillAndExpand"/>

                <Label x:Name="emptyLbl_2" HorizontalOptions="End"/>

            </StackLayout>

            <StackLayout Orientation="Horizontal" 
                         HorizontalOptions="FillAndExpand">

                <telerik:RadEntry x:Name="searchEntry"
                                  Placeholder="Search Promo Name"
                                  ClearButtonVisibility="Never"
                                  SelectionOnFocus="SelectAll"
                                  HorizontalOptions="FillAndExpand"
                                  Completed="searchEntry_Completed"
                                  BorderThickness="3"/>

                <telerik:RadButton x:Name="promoSearchBtn"
                                   Clicked="promoSearch_Clicked"
                                   BackgroundImage="ic_search.png"
                                   BackgroundColor="Transparent"
                                   IsVisible="True"
                                   HeightRequest="40"
                                   WidthRequest="40"
                                   HorizontalOptions="End"/>

            </StackLayout>

            <StackLayout Orientation="Horizontal">
                <telerik:RadButton x:Name="toggleFilterBtn"
                                   Text="Show Filled Rows"
                                   Clicked="OnToggleFilterButtonClicked"
                                   HorizontalOptions="Start"
                                   IsVisible="False"
                                   FontSize="12"/>

                <StackLayout Orientation="Horizontal" HorizontalOptions="EndAndExpand">
                    <Label Text="Total Rows: "
                           FontSize="12"/>

                    <Label x:Name="rowNo"
                           FontSize="12"/>

                </StackLayout>

            </StackLayout>

            <StackLayout Orientation="Horizontal" Padding="0,3,0,3" HorizontalOptions="FillAndExpand" BackgroundColor="WhiteSmoke">
                <Label Text="Promoter ID" HorizontalOptions="FillAndExpand" />
                <Label Text="Promoter Name" HorizontalOptions="FillAndExpand" />
                <Label Text="Transfer Qty" HorizontalOptions="FillAndExpand" />
            </StackLayout>

        </VerticalStackLayout>

        <CollectionView x:Name="collectionView" Grid.Row="1" SelectionMode="Single"
                        SelectionChanged="collectionView_SelectionChanged"
                        ItemTemplate="{StaticResource MyItemTemplateSelector}">
        </CollectionView>


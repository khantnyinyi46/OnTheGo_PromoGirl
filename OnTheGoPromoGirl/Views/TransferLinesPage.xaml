        </telerik:RadDataGrid>-->
        <CollectionView x:Name="collectionView" SelectionMode="Single" Grid.Row="1" SelectionChanged="collectionView_SelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="10" Orientation="Horizontal">
                        <Label Text="{Binding ItemID}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                        <Label Text="{Binding ItemName}" FontSize="Caption" HorizontalOptions="FillAndExpand" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <StackLayout Orientation="Horizontal" Grid.Row="2">
            <telerik:RadButton x:Name="confirmSyncBtn"
                               Text="Confirm and Sync"
                               Clicked="confirmSyncBtn_Clicked"
                               IsEnabled="False"
                               HorizontalOptions="FillAndExpand"/>
        </StackLayout>

    </Grid>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OnTheGoPromoGirl.Views"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="OnTheGoPromoGirl.AppShell"
             Shell.FlyoutBehavior="Flyout">

    <Shell.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource White}" StatusBarStyle="DarkContent"/>
    </Shell.Behaviors>
    <ShellContent 
                  ContentTemplate="{DataTemplate views:ActivatePage}"
                  Route="ActivatePage"
                  Shell.FlyoutBehavior="Disabled"
                  Shell.FlyoutItemIsVisible="False"/>

    <!--<FlyoutItem Title="New Stock Request">
        --><!--<ShellContent ContentTemplate="{DataTemplate views:NewStockRequestPage}"/>--><!--
        <ShellContent ContentTemplate="{DataTemplate views:SpinWheelPage}"/>

    </FlyoutItem>-->

</Shell>